# terminalv2 — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ----------------------------------------------------------------------------
# Supabase (project: terminalv2, region: eu-central-1)
# Get these from: Supabase Studio → Project Settings → API
# ----------------------------------------------------------------------------

# Public Supabase URL — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable key — safe to expose in browser
# Modern Supabase projects (created after Nov 2025) issue this format:
# sb_publishable_xxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — NEVER expose to the browser. Server-only.
# Modern Supabase format: sb_secret_xxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_...

# ----------------------------------------------------------------------------
# Site config
# ----------------------------------------------------------------------------

# Canonical URL for OpenGraph, sitemap, etc.
NEXT_PUBLIC_SITE_URL=https://terminal.airtuerk.de

# DEPRECATED (D-048): role assignment is now data-driven via the
# public.user_role_defaults table (seeded in migration 0030), which the signup
# trigger reads. This env var + the old app.initial_admin_email mechanism are no
# longer the source of truth and can be removed. Left here only for reference.
# INITIAL_ADMIN_EMAIL=buhara@airtuerk.de

# Draft visibility for the public frontend (Task 3).
# When "true", draft pages/blocks are read via the server-side service-role key
# so the site is testable before content is published. Defaults to ON in
# development and OFF in production when unset. Set "false" to force published-
# only (production-safe) behavior. Server-only — never exposed to the browser.
SHOW_DRAFTS=true

# ----------------------------------------------------------------------------
# Optional: only set in production / preview
# ----------------------------------------------------------------------------

# Vercel sets this automatically; not needed locally
# VERCEL_ENV=production

# For Phase 8 (RAG search) — Claude API
# ANTHROPIC_API_KEY=
