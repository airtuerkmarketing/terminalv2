if ($gitignore -notlike "*CHECKPOINT*") {
    $additions += "CHECKPOINT*.md"
}
if ($gitignore -notlike "*UPDATE_INSTRUCTIONS*") {
    $additions += "UPDATE_INSTRUCTIONS.md"
}
if ($gitignore -notlike "*verify*") {
    $additions += "verify*.ps1"
}

if ($additions.Count -gt 0) {
    $block = "`n`n# One-time scripts and reference docs (not project code)`n"
